# ─── Database ──────────────────────────────────────────────────────────────────
# Required. PostgreSQL connection string.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/team_management

# ─── Auth.js ───────────────────────────────────────────────────────────────────
# Required. Generate with: openssl rand -base64 33
AUTH_SECRET=
# Optional. Set to the OLD AUTH_SECRET during a key rotation to allow existing
# TOTP secrets to be lazily re-encrypted. Remove once all users have logged in.
AUTH_SECRET_PREVIOUS=

# Required. Public base URL of the app.
AUTH_URL=http://localhost:3000

# Optional OAuth providers — uncomment and fill in to enable.
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# ─── Admin seed ────────────────────────────────────────────────────────────────
# Required for `npm run db:seed`. Sets the email of the initial admin account.
ADMIN_EMAIL=admin@example.com
# Optional. Display name for the admin account.
ADMIN_NAME=Admin

# ─── Meilisearch ───────────────────────────────────────────────────────────────
# Optional. Defaults match the docker-compose.yml values.
# Change these if you connect to an external Meilisearch instance.
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=teambeheer_search_key

# ─── Audit log retention ───────────────────────────────────────────────────────
# Optional. Days to retain audit events (default: 730 = 2 years). Used by npm run db:purge-audit.
AUDIT_RETENTION_DAYS=730

# ─── Email (SMTP) ──────────────────────────────────────────────────────────────
# Optional. Leave blank to disable email features.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── Environment ───────────────────────────────────────────────────────────────
# Required. Identifies which environment this instance is running in.
# Valid values: development | staging | production
# Used by db:reset as a safety guard and by the app for environment-specific
# behaviour (e.g. staging banners, observability tags).
ENV=development

# ─── Database ──────────────────────────────────────────────────────────────────
# Required. PostgreSQL connection string.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/team_management

# ─── Auth.js ───────────────────────────────────────────────────────────────────
# Required. Generate with: openssl rand -base64 33
AUTH_SECRET=
# Optional. Set to the OLD AUTH_SECRET during a key rotation to allow existing
# TOTP secrets to be lazily re-encrypted. Remove once all users have logged in.
AUTH_SECRET_PREVIOUS=

# Required. Public base URL of the app (must match the reverse proxy URL in production).
AUTH_URL=http://localhost:3000

# OAuth providers — not currently in use. Uncomment and fill in if needed.
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# ─── Admin seed ────────────────────────────────────────────────────────────────
# Required for `npm run db:seed`. Sets the email of the initial admin account.
ADMIN_EMAIL=admin@example.com
# Optional. Display name for the admin account.
ADMIN_NAME=Admin

# ─── Meilisearch ───────────────────────────────────────────────────────────────
# MEILI_MASTER_KEY is read by the Meilisearch Docker container (docker-compose.yml).
# MEILISEARCH_KEY is used by the Next.js app to authenticate against Meilisearch.
# Both must be set to the same value. Change the defaults for all non-dev environments.
MEILI_MASTER_KEY=teambeheer_search_key
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=teambeheer_search_key

# ─── Audit log retention ───────────────────────────────────────────────────────
# Optional. Days to retain audit events (default: 730 = 2 years). Used by npm run db:purge-audit.
AUDIT_RETENTION_DAYS=730

# ─── LDAP / Active Directory (not yet implemented) ─────────────────────────────
# Uncomment and fill in when LDAP authentication is added.
# LDAP_URL=ldaps://your-ad-server.domain.nl:636
# LDAP_BIND_DN=CN=svc-teambeheer,OU=Service Accounts,DC=domain,DC=nl
# LDAP_BIND_PASSWORD=
# LDAP_SEARCH_BASE=OU=Users,DC=domain,DC=nl
# LDAP_USER_ATTRIBUTE=sAMAccountName

# ─── Notes ─────────────────────────────────────────────────────────────────────
# APP_VERSION is automatically injected from package.json by next.config.js.
# Do not set it here — a manual value will override the build-time version and go stale.

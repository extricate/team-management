{
  "name": "team-management",
  "version": "0.9.1",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "dev": "next dev",
    "dev:start": "docker compose up -d --wait db && npm run db:migrate && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:reset": "node --env-file=.env ./scripts/db-reset.mjs",
    "db:status": "node --env-file=.env ./scripts/db-status.mjs",
    "db:studio": "drizzle-kit studio",
    "db:seed": "node --env-file=.env --import tsx ./lib/db/seed.ts",
    "db:seed:demo": "node --env-file=.env --import tsx ./lib/db/seed/index.ts",
    "db:purge-audit": "node --env-file=.env ./scripts/purge-audit.mjs",
    "search:reindex": "node --env-file=.env --import tsx ./lib/search/reindex.ts"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@types/qrcode": "^1.5.6",
    "drizzle-orm": "^0.36.4",
    "meilisearch": "^0.57.0",
    "next": "^16.2.4",
    "next-auth": "^5.0.0-beta.19",
    "postgres": "^3.4.9",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^3.25.76"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.60.0",
    "@rijkshuisstijl-community/components-react": "^15.0.2",
    "@rijkshuisstijl-community/design-tokens": "^15.0.0",
    "@rijkshuisstijl-community/font": "^1.1.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}

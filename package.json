{
  "name": "team-management",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:start": "docker compose up -d --wait db && npm run db:migrate && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "node --env-file=.env --env-file=.env.local --import tsx ./lib/db/seed.ts",
    "db:seed:demo": "node --env-file=.env --env-file=.env.local --import tsx ./lib/db/seed/index.ts",
    "search:reindex": "node --env-file=.env --env-file=.env.local --import tsx ./lib/search/reindex.ts"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@types/qrcode": "^1.5.6",
    "drizzle-orm": "^0.36.4",
    "meilisearch": "^0.57.0",
    "next": "^16.2.4",
    "next-auth": "^5.0.0-beta.19",
    "postgres": "^3.4.9",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@rijkshuisstijl-community/components-react": "^15.0.2",
    "@rijkshuisstijl-community/design-tokens": "^15.0.0",
    "@rijkshuisstijl-community/font": "^1.1.4",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.57.1",
    "eslint-config-next": "^16.2.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
